    "splash": { "backgroundColor": "#13522e" },
    "ios": { "bundleIdentifier": "com.shamba.africa", "supportsTablet": false },
    "android": { "package": "com.shamba.africa", "adaptiveIcon": { "backgroundColor": "#13522e" } },
    "plugins": ["expo-router", "expo-font"],
