{
  "expo": {
    "name": "Shamba",
    "slug": "shamba-africa",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "backgroundColor": "#13522e",
      "resizeMode": "contain"
    },
    "ios": {
      "bundleIdentifier": "com.shamba.africa",
      "supportsTablet": false
    },
    "android": {
      "package": "com.shamba.africa",
      "adaptiveIcon": {
        "backgroundColor": "#13522e"
      }
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#13522e",
          "resizeMode": "contain"
        }
      ]
    ],
    "scheme": "shamba",
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "your-project-id"
      }
    },
    "experiments": {
      "typedRoutes": true
    }
  }
}
